# OTel — set to activate frontend tracing
# NOTE: these are baked into the static bundle at `npm run build` time (Vite
# inlines import.meta.env.VITE_*), not read at container runtime — see
# .k8s/Dockerfile / Makefile's build-image target for how they're passed in.
VITE_OTEL_ENABLED=false
# Relative path, routed through Kong (see app3-gateway/manifests/kong-otel-browser-route.yaml)
# so the browser POSTs to the same origin as the rest of the API — no CORS,
# no hardcoded host.
VITE_OTEL_EXPORTER_ENDPOINT=/api/otel/v1/traces

# OpenReplay — set BOTH to activate session recording
# Requires HTTPS on the cluster — do not activate in local dev
VITE_OPENREPLAY_PROJECT_KEY=
VITE_OPENREPLAY_INGEST_POINT=
